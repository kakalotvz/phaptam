generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum FavoriteType {
  AUDIO
  VIDEO
}

enum FeedbackType {
  FEEDBACK
  REPORT
}

enum NewsSourceType {
  RSS
  MANUAL
}

enum ReminderResumeMode {
  RESUME
  RESTART
}

enum ScriptureKind {
  CHANT
  READING
}

enum AudioCategoryKind {
  AUDIO
  CHANT
  READING
}

model User {
  id                          String                       @id @default(uuid())
  email                       String                       @unique
  username                    String?                      @unique
  passwordHash                String
  name                        String?
  birthDate                   DateTime?                    @map("birth_date")
  active                      Boolean                      @default(true)
  role                        Role                         @default(USER)
  otp                         String?
  otpExpiry                   DateTime?                    @map("otp_expiry")
  playlists                   Playlist[]
  favorites                   Favorite[]
  histories                   History[]
  progresses                  AudioProgress[]
  feedback                    Feedback[]
  downloads                   UserDownload[]
  scriptureReminders          ScriptureReminder[]
  scriptureReadingPreferences ScriptureReadingPreference[]
  createdAt                   DateTime                     @default(now()) @map("created_at")
  updatedAt                   DateTime                     @updatedAt @map("updated_at")
}

model AudioCategory {
  id          String          @id @default(uuid())
  kind        AudioCategoryKind @default(AUDIO)
  name        String
  description String?
  parentId    String?         @map("parent_id")
  parent      AudioCategory?  @relation("AudioCategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    AudioCategory[] @relation("AudioCategoryTree")
  audios      Audio[]
  scriptures  Scripture[]
  createdAt   DateTime        @default(now()) @map("created_at")

  @@index([parentId])
  @@index([kind])
}

model VideoCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  videos      Video[]
  createdAt   DateTime @default(now()) @map("created_at")
}

model Audio {
  id            String          @id @default(uuid())
  title         String
  description   String?
  audioUrl      String          @map("audio_url")
  thumbnailUrl  String?         @map("thumbnail_url")
  categoryId    String          @map("category_id")
  duration      Int
  viewCount     Int             @default(0) @map("view_count")
  category      AudioCategory   @relation(fields: [categoryId], references: [id])
  playlistItems PlaylistItem[]
  progresses    AudioProgress[]
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
}

model Video {
  id           String        @id @default(uuid())
  title        String
  description  String?
  videoUrl     String        @map("video_url")
  thumbnailUrl String?       @map("thumbnail_url")
  categoryId   String        @map("category_id")
  teacher      String?
  viewCount    Int           @default(0) @map("view_count")
  category     VideoCategory @relation(fields: [categoryId], references: [id])
  histories    History[]
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
}

model Playlist {
  id        String         @id @default(uuid())
  userId    String         @map("user_id")
  name      String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     PlaylistItem[]
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
}

model PlaylistItem {
  id         String   @id @default(uuid())
  playlistId String   @map("playlist_id")
  audioId    String   @map("audio_id")
  orderIndex Int      @map("order_index")
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  audio      Audio    @relation(fields: [audioId], references: [id], onDelete: Cascade)

  @@unique([playlistId, audioId])
  @@index([playlistId, orderIndex])
}

model Favorite {
  id        String       @id @default(uuid())
  userId    String       @map("user_id")
  type      FavoriteType
  contentId String       @map("content_id")
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now()) @map("created_at")

  @@unique([userId, type, contentId])
  @@index([type, contentId])
}

model History {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  videoId   String   @map("video_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  watchedAt DateTime @default(now()) @map("watched_at")
}

model AudioProgress {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  audioId      String   @map("audio_id")
  lastPosition Int      @map("last_position")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  audio        Audio    @relation(fields: [audioId], references: [id], onDelete: Cascade)
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([userId, audioId])
}

model UserDownload {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  mediaKey     String   @map("media_key")
  mediaType    String   @map("media_type")
  contentId    String   @map("content_id")
  title        String
  url          String
  thumbnailUrl String?  @map("thumbnail_url")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([userId, mediaKey])
  @@index([userId, mediaType])
  @@map("user_downloads")
}

model Quote {
  id        String   @id @default(uuid())
  content   String
  imageUrl  String?  @map("image_url")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
}

model Banner {
  id        String   @id @default(uuid())
  imageUrl  String   @map("image_url")
  link      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
}

model MeditationProgram {
  id          String   @id @default(uuid())
  title       String
  description String?
  duration    Int
  audioUrl    String?  @map("audio_url")
  imageUrl    String?  @map("image_url")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
}

model Feedback {
  id        String       @id @default(uuid())
  userId    String?      @map("user_id")
  content   String
  type      FeedbackType
  user      User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime     @default(now()) @map("created_at")
}

model RssSource {
  id        String   @id @default(uuid())
  name      String
  url       String
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model NewsCategory {
  id          String     @id @default(uuid())
  name        String
  description String?
  items       NewsItem[]
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
}

model NewsItem {
  id           String         @id @default(uuid())
  sourceId     String?        @map("source_id")
  categoryId   String?        @map("category_id")
  title        String
  link         String?        @unique
  summary      String?
  content      String?
  imageUrl     String?        @map("image_url")
  sourceName   String?        @map("source_name")
  sourceType   NewsSourceType @default(RSS) @map("source_type")
  shareEnabled Boolean        @default(true) @map("share_enabled")
  viewCount    Int            @default(0) @map("view_count")
  publishedAt  DateTime       @default(now()) @map("published_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  category     NewsCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([publishedAt])
}

model Scripture {
  id                 String              @id @default(uuid())
  kind               ScriptureKind       @default(CHANT)
  title              String
  description        String?
  content            String?
  backgroundImageUrl String?             @map("background_image_url")
  categoryId         String?             @map("category_id")
  category           AudioCategory?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  viewCount          Int                 @default(0) @map("view_count")
  lines              ScriptureLine[]
  reminders          ScriptureReminder[]
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  @@index([categoryId])
  @@index([kind])
}

model ScriptureLine {
  id          String    @id @default(uuid())
  scriptureId String    @map("scripture_id")
  content     String
  startTime   Float     @map("start_time")
  orderIndex  Int       @map("order_index")
  scripture   Scripture @relation(fields: [scriptureId], references: [id], onDelete: Cascade)

  @@unique([scriptureId, startTime])
  @@index([scriptureId, orderIndex])
}

model ScriptureReminder {
  id            String             @id @default(uuid())
  userId        String?            @map("user_id")
  scriptureId   String             @map("scripture_id")
  title         String
  timeOfDay     String             @map("time_of_day")
  weekdays      Int[]
  resumeMode    ReminderResumeMode @default(RESUME) @map("resume_mode")
  active        Boolean            @default(true)
  lastLineIndex Int                @default(0) @map("last_line_index")
  user          User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  scripture     Scripture          @relation(fields: [scriptureId], references: [id], onDelete: Cascade)
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@index([userId])
  @@index([scriptureId])
}

model ScriptureReadingPreference {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  preferenceKey String   @map("preference_key")
  scriptureId   String?  @map("scripture_id")
  speed         Float
  speedMode     String   @default("normal") @map("speed_mode")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([userId, preferenceKey])
  @@index([userId])
  @@index([scriptureId])
  @@map("scripture_reading_preferences")
}
