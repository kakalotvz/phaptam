<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Native splash Android 12+ chỉ giữ nền trơn; logo + chữ được hiển thị ở Flutter splash. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_blank</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:statusBarColor">#2D1008</item>
        <item name="android:navigationBarColor">#2D1008</item>
    </style>

    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
